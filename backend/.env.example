# Backend security
APP_SECRET_KEY=replace-with-a-long-random-secret

# Database
SQLITE_URL=sqlite:///data/app.db

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me
NEO4J_DATABASE=neo4j

# LLM
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=1
LLM_CONCURRENCY=5

# Embedding
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
EMBEDDING_TIMEOUT_SECONDS=60
EMBEDDING_MAX_RETRIES=1
EMBEDDING_MATCH_THRESHOLD=0.65
EMBEDDING_MIN_MATCHED_FACETS=2

# Dify
DIFY_BASE_URL=http://localhost/v1
DIFY_API_KEY=
DIFY_TIMEOUT_SECONDS=120
CAREER_GOAL_DIFY_BASE_URL=
CAREER_GOAL_DIFY_API_KEY=
CAREER_GOAL_KNOWSEARCH_DIFY_API_KEY=
CAREER_GOAL_DIFY_TIMEOUT_SECONDS=120

# Qdrant
QDRANT_PATH=data/qdrant
QDRANT_JOB_GROUP_COLLECTION_NAME=job_group_embeddings
QDRANT_CAREER_GROUP_COLLECTION_NAME=career_group_embeddings
