# ============================================
# Career Planning Agent - Deployment Config
# ============================================
# Copy this file to .env and fill in your values.
# Place at project root as: cp deploy/.env.example .env
#
# docker-compose.yml reads env vars from this file.
# All settings below are referenced in docker-compose.yml
# and passed as environment variables to the backend container.
# ============================================

# ---- Security (REQUIRED) ----
APP_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# ---- Domain (REQUIRED) ----
# Your server domain or IP for CORS and Nginx
# Example: APP_DOMAIN=example.com  or  APP_DOMAIN=123.45.67.89
APP_DOMAIN=localhost

# ---- Neo4j (REQUIRED) ----
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-on-deployment

# ---- AI: LLM (optional - app starts without these) ----
# Any OpenAI-compatible API provider
# Examples: OpenAI, DeepSeek, Azure OpenAI, Ollama, etc.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
# LLM_TIMEOUT_SECONDS=60
# LLM_MAX_RETRIES=1
# LLM_CONCURRENCY=5

# ---- AI: Embedding (optional) ----
# OpenAI-compatible embedding API
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=
# EMBEDDING_TIMEOUT_SECONDS=60
# EMBEDDING_MAX_RETRIES=1
# EMBEDDING_MATCH_THRESHOLD=0.65
# EMBEDDING_MIN_MATCHED_FACETS=2

# ---- AI: Dify (optional) ----
# Dify workflow API for resume parsing and report generation
# USE_LOCAL_COMPETENCY_PROFILE=true uses local implementation instead
DIFY_BASE_URL=
DIFY_API_KEY=
USE_LOCAL_COMPETENCY_PROFILE=true
# DIFY_TIMEOUT_SECONDS=120
