# ============================================
# Career Planning Agent - Deployment Config
# ============================================
# Copy this file to .env and fill in your values.
# Place at project root as: cp deploy/.env.example .env

# ---- Security (REQUIRED) ----
APP_SECRET_KEY=replace-with-a-long-random-secret-at-least-32-chars

# ---- Domain (REQUIRED) ----
# Your server domain or IP for CORS and Nginx
# Example: APP_DOMAIN=example.com  or  APP_DOMAIN=123.45.67.89
APP_DOMAIN=localhost

# ---- Neo4j ----
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-on-deployment

# ---- AI Services (optional - app works without these) ----
# LLM
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Embedding
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=

# Dify
DIFY_BASE_URL=
DIFY_API_KEY=
USE_LOCAL_COMPETENCY_PROFILE=true
