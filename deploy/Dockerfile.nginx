# ============================================
# Career Planning Agent - Nginx Dockerfile
# Multi-stage: builds frontend, serves static files + proxies API
# ============================================
FROM node:22-alpine AS frontend-builder

WORKDIR /app

# Copy dependency files
COPY myapp/package.json ./

# Install dependencies (use install instead of ci for cross-platform compatibility)
RUN npm install --ignore-scripts

# Copy all source code
COPY myapp/ ./

# Run postinstall setup and build
RUN npx --yes max setup && \
    node scripts/patch-umi-tsconfig.cjs && \
    npm run build

# ============================================
FROM nginx:alpine

# Copy nginx reverse proxy config
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf

# Copy built frontend static files
COPY --from=frontend-builder /app/dist /usr/share/nginx/html

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
